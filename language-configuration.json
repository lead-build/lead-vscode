{
    "comments": {
        "lineComment": {
            "comment": "//",
            "noIndent": false
        },
        "blockComment": ["/*", "*/"]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["let", "in"]
    ],
    "autoClosingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^(.*\\{[^\\}]*$|.*\\[[^\\]]*$|.*\\([^\\)]*$|.*\\b(?:let|bind)\\b\\s*$)",
        "decreaseIndentPattern": "^\\s*(?:\\}|\\]|\\)|in)\\b"
    }
}
